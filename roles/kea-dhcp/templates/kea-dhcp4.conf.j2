#
#  -*- coding:utf-8 mode:bash -*-
# This file is generated by ansible.
{# 日付の取得 #}
# last update: {{ '%Y-%m-%d %H:%M:%S %Z' | strftime(ansible_date_time.epoch) }}

#
# kea-dhcp4 configuration
# 参考) https://www.server-world.info/query?os=Ubuntu_24.04&p=kea&f=1
{
"Dhcp4": {
        "interfaces-config": {
            # listenするインターフェースを指定 (複数指定可)
            "interfaces": [ "{{ kea_dhcp_interfaces | join('", "') }}" ]
        },
        # 期限切れリースの各設定
        "expired-leases-processing": {
            "reclaim-timer-wait-time": {{ kea_reclaim_timer_wait_time|default(600, true) }},
            "flush-reclaimed-timer-wait-time": {{ kea_flush_reclaimed_timer_wait_time|default(600, true) }},
            "hold-reclaimed-time": {{ kea_hold_reclaimed_time|default(600, true) }},
            "max-reclaim-leases": {{ kea_max_reclaim_leases|default(100, true) }},
            "max-reclaim-time": {{ kea_max_reclaim_time|default(600, true) }},
            "unwarned-reclaim-cycles": {{ kea_unwarned_reclaim_cycles|default(3, true) }}
        },
        # 更新プロセスを開始する間隔 (秒)
        "renew-timer": {{ kea_renew_timer_wait_time|default(600, true) }},
        # 再バインドプロセスを開始する間隔 (秒)
        "rebind-timer": {{ kea_rebind_timer_wait_time|default(600, true) }},
        # リースの有効期間 (秒)
        "valid-lifetime": {{ kea_valid_lifetime|default(3600, true) }},
        "option-data": [
            {% set option_data_sep = joiner(',\n') %}
            {% if kea_dns_servers | default([], true) | length > 0 %}
            {{ option_data_sep() }}
            {
                # 使用する DNS サーバーを指定
                # 複数指定する場合はカンマ区切り
                "name": "domain-name-servers",
                "data": "{{ kea_dns_servers | join(',') }}"
            }
            {% endif %}
            {% if kea_domain_name | default('', true) | length > 0 %}
            {{ option_data_sep() }}
            {
                # ドメイン名を指定
                "name": "domain-name",
                "data": "{{ kea_domain_name }}"
            }
            {% endif %}
            {% if kea_domain_search | default([], true) | length > 0 %}
            {{ option_data_sep() }}
            {
                # ドメインのサーチベースを指定
                # 複数指定する場合はカンマ区切り
                "name": "domain-search",
                "data": "{{ kea_domain_search | join(',') }}"
            }
            {% endif %}
        ],
        # リースデータベースの設定
        "lease-database": {
            "type": "{{ kea_lease_db_type|default('memfile', true) }}",
            "persist": true,
            "name": "{{ kea_lease_db_name|default('kea-leases', true) }}"
        },
        {% if ( ( kea_subnet | default('', true) ) | length > 0 ) and ( ( kea_gateway | default('', true) ) | length > 0 ) %}
        # ipv4サブネットの設定
        "subnet4": [
            {
                "id": 1,
                # DHCP を使用するサブネットを指定
                "subnet": "{{ kea_subnet }}",
                {% if ( kea_pool | default('', true) ) | length > 0 %}
                # 貸し出す IP アドレスの範囲を指定
                "pools": [ { "pool": "{{ kea_pool }}" } ],
                {% endif %}
                "option-data": [
                    {
                        # ゲートウェイアドレスを指定
                        "name": "routers",
                        "data": "{{ kea_gateway }}"
                    }
                ]
            }
        ],
        {% endif %}
        # ロギングの設定
        "loggers": [
            {
                "name": "kea-dhcp4",
                "output_options": [
                    {
                        "output": "{{kea_dhcp_log_file|default('/var/log/kea-dhcp4.log', true) }}",
                        "maxsize": {{ kea_dhcp_log_maxsize|default(10485760, true) }},
                        "maxver": {{ kea_dhcp_log_maxver|default(5, true) }}
                    }
                ],
                "severity": "INFO",
                "debuglevel": 0
            }
        ]
    }
}