#!/usr/bin/env bash
# -*- coding:utf-8 mode:bash -*-
#
# Debianターゲットで互換libyangをdebパッケージ化する
#
# This file is generated by ansible.
{# 日付の取得 #}
# last update: {{ '%Y-%m-%d %H:%M:%S %Z' | strftime(ansible_date_time.epoch) }}

set -euo pipefail

# debパッケージビルド時に対話的な質問を抑制する
export DEBIAN_FRONTEND=noninteractive

install_build_dependencies(){

    # apt-get が利用可能な場合は apt-get を使用してビルドに必要なパッケージを導入する
    if command -v apt-get >/dev/null 2>&1; then
        apt-get update
        apt-get -y --no-install-recommends install git cmake pkg-config libpcre2-dev dpkg-dev build-essential
        return 0
    fi

    # dnf が利用可能な場合は dnf を使用してビルドに必要なパッケージを導入する
    if command -v dnf >/dev/null 2>&1; then
        dnf -y install git cmake pkgconf-pkg-config pcre2-devel gcc gcc-c++ make dpkg dpkg-devel
        return 0
    fi

    echo "Unsupported build host: neither apt-get nor dnf is available" >&2
    return 1
}

detect_deb_arch(){

    # dpkg が利用可能な場合は dpkg を使用してアーキテクチャを取得する
    if command -v dpkg >/dev/null 2>&1; then
        dpkg --print-architecture
        return 0
    fi

    case "$(uname -m)" in
        x86_64) echo "amd64" ;;
        aarch64) echo "arm64" ;;
        *)
            echo "Unsupported architecture for deb packaging: $(uname -m)" >&2
            return 1
            ;;
    esac
}

detect_deb_multiarch(){

    # dpkg-architecture が利用可能な場合は dpkg-architecture を使用して multiarch パスを取得する
    if command -v dpkg-architecture >/dev/null 2>&1; then
        dpkg-architecture -qDEB_HOST_MULTIARCH
        return 0
    fi

    case "$(uname -m)" in
        x86_64) echo "x86_64-linux-gnu" ;;
        aarch64) echo "aarch64-linux-gnu" ;;
        *)
            echo "Unsupported architecture for multiarch path: $(uname -m)" >&2
            return 1
            ;;
    esac
}

build_libyang(){
    local libyang_version
    local libyang_deb_revision
    local srcdir
    local pkgroot
    local runtime_stage
    local runtime_pkg
    local alt_runtime_pkg
    local dev_stage
    local arch
    local runtime_deb
    local dev_deb
    local runtime_control_template
    local dev_control_template
    local runtime_control
    local dev_control
    local multiarch

    # libyangのバージョン
    libyang_version="{{ frr_libyang_version }}"
    # debパッケージのリビジョン
    libyang_deb_revision="{{ frr_libyang_deb_revision }}"
    # ソース展開先ディレクトリ
    srcdir="/tmp/libyang-src-${libyang_version}"
    # debパッケージの作業ディレクトリ
    pkgroot="/tmp/libyang-pkg-${libyang_version}"
    # debパッケージの作業ディレクトリの下に, ランタイム用と開発用の2つのステージングディレクトリを作成する
    runtime_stage="${pkgroot}/runtime"
    dev_stage="${pkgroot}/dev"
    # debパッケージのランタイムパッケージ名
    # playbookから渡された実行時指定を優先する
    runtime_pkg="${LIBYANG_RUNTIME_PKG:-{{ frr_libyang_runtime_pkg_name | default('libyang2') }}}"

    # debパッケージのコントロールファイルのテンプレート
    runtime_control_template="/tmp/install-libyang-runtime.control.in"
    # 開発用パッケージのコントロールファイルのテンプレート
    dev_control_template="/tmp/install-libyang-dev.control.in"
    # debパッケージのコントロールファイルのパス
    runtime_control="${runtime_stage}/DEBIAN/control"
    # 開発用パッケージのコントロールファイルのパス
    dev_control="${dev_stage}/DEBIAN/control"

    #
    # libyangのソースコードをGitリポジトリから取得して構築する
    #

    #
    # 開発環境を導入する
    #
    install_build_dependencies

    # debパッケージ関連コマンドが利用可能であることを確認する
    command -v dpkg >/dev/null 2>&1
    command -v dpkg-deb >/dev/null 2>&1

    # debパッケージのアーキテクチャを取得する
    arch="$(detect_deb_arch)"
    multiarch="$(detect_deb_multiarch)"

    # 互換ランタイムパッケージ名を判定する
    case "${runtime_pkg}" in
        libyang2t64)
            alt_runtime_pkg="libyang2"
            ;;
        libyang2)
            alt_runtime_pkg="libyang2t64"
            ;;
        *)
            echo "Unsupported runtime package name: ${runtime_pkg}" >&2
            return 1
            ;;
    esac

    # debパッケージのファイルパス
    runtime_deb="/tmp/${runtime_pkg}_${libyang_version}-${libyang_deb_revision}_${arch}.deb"
    # 開発用パッケージのファイルパス
    dev_deb="/tmp/libyang2-dev_${libyang_version}-${libyang_deb_revision}_${arch}.deb"

    #
    # ソースコード格納先ディレクトリ, debパッケージ作業ディレクトリを作成する
    #
    rm -rf "${srcdir}"
    rm -rf "${pkgroot}"

    # 既存のdebパッケージを削除する
    rm -f "${runtime_deb}" "${dev_deb}"

    # libyangのソースコードをGitリポジトリから取得する
    git clone "{{ frr_libyang_git_url }}" "${srcdir}"
    cd "${srcdir}"
    git checkout "{{ frr_libyang_git_ref_prefix }}{{ frr_libyang_version }}"

    # libyangのソースコードをビルドする
    cmake -S . -B build \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr \
        -DCMAKE_INSTALL_LIBDIR="lib/${multiarch}" \
        -DENABLE_TESTS=OFF
    cmake --build build -j"$(nproc)"

    # libyangのソースコードをruntime_stageディレクトリ配下にインストールする
    mkdir -p "${runtime_stage}"
    DESTDIR="${runtime_stage}" cmake --install build

    # 開発用ファイルを runtime ステージから分離し, libyang2-dev パッケージとして管理する
    mkdir -p "${dev_stage}/usr"

    # ヘッダファイルを dev ステージに移動する
    if [[ -d "${runtime_stage}/usr/include" ]]; then
	    mv "${runtime_stage}/usr/include" "${dev_stage}/usr/"
    fi

    # CMakeファイルを dev ステージに移動する
    if [[ -d "${runtime_stage}/usr/lib/${multiarch}/cmake" ]]; then
	    mkdir -p "${dev_stage}/usr/lib/${multiarch}"
	    mv "${runtime_stage}/usr/lib/${multiarch}/cmake" "${dev_stage}/usr/lib/${multiarch}/"
    fi

    # pkgconfigファイルを dev ステージに移動する
    if [[ -d "${runtime_stage}/usr/lib/${multiarch}/pkgconfig" ]]; then
	    mkdir -p "${dev_stage}/usr/lib/${multiarch}"
	    mv "${runtime_stage}/usr/lib/${multiarch}/pkgconfig" "${dev_stage}/usr/lib/${multiarch}/"
    fi

    # libyang.soを dev ステージに移動する
    # libyang.soがシンボリックリンク, または, 実体ファイルの場合は,
    # dev ステージに移動する
    if [[ -L "${runtime_stage}/usr/lib/${multiarch}/libyang.so" || -f "${runtime_stage}/usr/lib/${multiarch}/libyang.so" ]]; then
    	mkdir -p "${dev_stage}/usr/lib/${multiarch}"
    	mv "${runtime_stage}/usr/lib/${multiarch}/libyang.so" "${dev_stage}/usr/lib/${multiarch}/"
    fi

    #
    # debパッケージのコントロールファイルを作成する
    #
    mkdir -p "${runtime_stage}/DEBIAN" "${dev_stage}/DEBIAN"

    # コントロールファイルをコピーする
    cp -f "${runtime_control_template}" "${runtime_control}"
    cp -f "${dev_control_template}" "${dev_control}"

    # コントロールファイルの変数を置換する
    sed -i \
        -e "s|@RUNTIME_PKG@|${runtime_pkg}|g" \
        -e "s|@ALT_RUNTIME_PKG@|${alt_runtime_pkg}|g" \
        -e "s|@LIBYANG_VERSION@|${libyang_version}|g" \
        -e "s|@LIBYANG_DEB_REVISION@|${libyang_deb_revision}|g" \
        -e "s|@ARCH@|${arch}|g" \
        "${runtime_control}" "${dev_control}"

    #
    # debパッケージを作成する
    #
    dpkg-deb --build "${runtime_stage}" "${runtime_deb}"
    dpkg-deb --build "${dev_stage}" "${dev_deb}"

    # ディレクトリのパーミッションを変更する
    find "${pkgroot}" -type d -exec chmod o+rx {} \;
    # debパッケージのパーミッションを変更する
    find "${pkgroot}" -type f -name '*.deb' -exec chmod o+r {} \;
}

#
# メイン処理
#
main(){

    # libyangのソースコードをビルドしてインストールする
    build_libyang
}

main "$@"
