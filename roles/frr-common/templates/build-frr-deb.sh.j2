#!/usr/bin/env bash
# -*- coding:utf-8 mode:bash -*-
#
# FRRのdebパッケージをビルドする
#
# 実行時パラメタ環境変数
#  - FRR_VERSION: ビルド対象のFRR版数
#  - FRR_GIT_URL: FRRソース取得先のGitリポジトリURL
#  - FRR_GIT_REF_PREFIX: FRRソース取得先のGitリポジトリのタグ名の接頭辞
#  - LIBYANG_VERSION: ビルド対象のlibyang版数
#  - LIBYANG_GIT_URL: libyangソース取得先のGitリポジトリURL
#  - LIBYANG_GIT_REF_PREFIX: libyangソース取得先のGitリポジトリのタグ名の接頭辞
#
# This file is generated by ansible.
{# 日付の取得 #}
# last update: {{ '%Y-%m-%d %H:%M:%S %Z' | strftime(ansible_date_time.epoch) }}

set -euo pipefail

#
# 環境変数パラメタが設定されていない場合はエラー終了する
#
: "${FRR_VERSION:?FRR_VERSION is required}"
: "${FRR_GIT_URL:?FRR_GIT_URL is required}"
: "${FRR_GIT_REF_PREFIX:?FRR_GIT_REF_PREFIX is required}"
: "${LIBYANG_VERSION:?LIBYANG_VERSION is required}"
: "${LIBYANG_GIT_URL:?LIBYANG_GIT_URL is required}"
: "${LIBYANG_GIT_REF_PREFIX:?LIBYANG_GIT_REF_PREFIX is required}"

# debパッケージビルド時に対話的な質問を抑制する
export DEBIAN_FRONTEND=noninteractive

# 作業ディレクトリ
# Dockerfile.ubuntu内のWORKDIRと合わせること
workdir="{{ frr_build_container_workdir }}"

#
# libyangのソースコードをビルドしてインストールする
#
# frr-10系を構築する場合, libyangのバージョンがUbuntu 24.04のリポジトリに存在する
# バージョンより新しいため, 先にlibyangをソースビルドしてインストールしてから
# FRRをビルドする
#
build_libyang(){
    local libyang_srcdir
    local srcdir

    #
    # libyangを構築するためのディレクトリを作成する
    #
    libyang_srcdir="${workdir}/libyang-src-${LIBYANG_VERSION}"
    srcdir="${workdir}/frr-src-${FRR_VERSION}"

    if [[ -d "${libyang_srcdir}" ]]; then
        rm -rf "${libyang_srcdir}"
    fi

    if [[ -d "${srcdir}" ]]; then
        rm -rf "${srcdir}"
    fi

    #
    # libyangのソースコードをGitリポジトリから取得する
    #
    git clone "${LIBYANG_GIT_URL}" "${libyang_srcdir}"
    cd "${libyang_srcdir}"
    git checkout "${LIBYANG_GIT_REF_PREFIX}${LIBYANG_VERSION}"

    #
    # libyangのビルドに必要なパッケージを導入する
    #
    apt-get update
    apt-get -y --no-install-recommends install libyang2 || true
    apt-get -y --no-install-recommends install cmake pkg-config libpcre2-dev

    #
    # libyangのソースコードをビルドしてインストールする
    #
    cmake -S . -B build -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX=/usr -DENABLE_TESTS=OFF
    cmake --build build -j"$(nproc)"
    cmake --install build
    ldconfig

    #
    # libyang2-devのダミーパッケージを作成してインストールする
    #
    printf '%s\n' \
    'Section: misc' \
    'Priority: optional' \
    'Standards-Version: 4.6.0' \
    'Package: libyang2-dev' \
    "Version: ${LIBYANG_VERSION}" \
    'Maintainer: frr-common builder <root@localhost>' \
    'Architecture: amd64' \
    'Description: Dummy libyang2-dev package for FRR build-dep on Ubuntu 24.04' \
    > /tmp/libyang2-dev-control

    cd /tmp
    equivs-build /tmp/libyang2-dev-control
    dpkg -i "/tmp/libyang2-dev_${LIBYANG_VERSION}_amd64.deb"
}

#
# FRRのdebパッケージをビルドする
#
build_frr(){
    local srcdir

    #
    # FRRのソースコードをGitリポジトリから取得する
    #

    # ソースコード展開先ディレクトリを一旦削除し
    # Gitリポジトリから取得したソースコードに置き換える
    srcdir="${workdir}/frr-src-${FRR_VERSION}"

    if [[ -d "${srcdir}" ]]; then
        rm -rf "${srcdir}"
    fi

    # Gitリポジトリからソースコードを取得する
    git clone "${FRR_GIT_URL}" "${srcdir}"
    cd "${srcdir}"
    git checkout "${FRR_GIT_REF_PREFIX}${FRR_VERSION}"

    #
    # 開発環境を導入する
    #
    # カレントディレクトリ(.)にあるDebianパッケージ定義を読み取り,
    # ビルドに必要な依存パッケージを apt-get で自動導入する
    #
    apt-get -y --no-install-recommends build-dep .
    # FRRのDebianパッケージをビルドする
    dpkg-buildpackage -us -uc -b

    # ビルドされたdebパッケージを /work/output にコピーする
    # /workは, ホスト側のディレクトリにマウントされている
    # dockerコンテナ内での作業ディレクトリとして, playbook側で
    # 指定することを前提としている。
    mkdir -p "${workdir}/output"

    # ビルドされたdebパッケージを /work/output にコピーする
    find "${workdir}" -maxdepth 1 -type f -name '*.deb' -exec cp -f {} "${workdir}/output/" \;
    find "${srcdir}" -maxdepth 1 -type f -name '*.deb' -exec cp -f {} "${workdir}/output/" \;
}

#
# メイン処理
#
main(){

    # libyangのソースコードをビルドしてインストールする
    build_libyang
    # FRRのdebパッケージをビルドする
    build_frr
}

main "$@"
