#!/usr/bin/env bash
# -*- coding:utf-8 mode:bash -*-
#
# FRRのrpmパッケージをビルドする
#
# 実行時パラメタ環境変数
#  - FRR_VERSION: ビルド対象のFRR版数
#  - FRR_GIT_URL: FRRソース取得先のGitリポジトリURL
#  - FRR_GIT_REF_PREFIX: FRRソース取得先のGitリポジトリのタグ名の接頭辞
#
# This file is generated by ansible.
{# 日付の取得 #}
# last update: {{ '%Y-%m-%d %H:%M:%S %Z' | strftime(ansible_date_time.epoch) }}

set -euo pipefail

#
# 環境変数パラメタが設定されていない場合はエラー終了する
#
: "${FRR_VERSION:?FRR_VERSION is required}"
: "${FRR_GIT_URL:?FRR_GIT_URL is required}"
: "${FRR_GIT_REF_PREFIX:?FRR_GIT_REF_PREFIX is required}"

build_frr(){
    local srcdir
    local specfile

    #
    # FRRを構築するためのディレクトリを作成する
    #
    srcdir="/work/frr-src-${FRR_VERSION}"
    rm -rf "${srcdir}"

    #
    # FRRのソースコードをGitリポジトリから取得する
    #
    git clone "${FRR_GIT_URL}" "${srcdir}"
    cd "${srcdir}"
    git checkout "${FRR_GIT_REF_PREFIX}${FRR_VERSION}"

    #
    # ソースコード中のrpm specファイルを取得する
    #
    if [[ -f redhat/frr.spec ]]; then
        specfile="redhat/frr.spec"
    elif [[ -f redhat/frr.spec.in ]]; then
        specfile="redhat/frr.spec"
        sed "s/@VERSION@/${FRR_VERSION}/g" redhat/frr.spec.in > "${specfile}"
    else
        echo "FRR spec file was not found under redhat/." >&2
        exit 1
    fi

    #
    # FRRのrpmパッケージをビルドするために必要なパッケージを導入する
    #
    dnf -y builddep --spec -D "with_rpki 0" -D "with_docs 0" "${specfile}"

    #
    # configureスクリプトを生成する
    #
    ./bootstrap.sh

    #
    # FRRのrpmパッケージをビルドする
    #

    # RPMビルド用のディレクトリを作成する
    rm -rf /work/rpmbuild
    mkdir -p /work/rpmbuild/{BUILD,BUILDROOT,RPMS,SOURCES,SPECS,SRPMS}

    # FRRのソースコードをtar.gz形式に圧縮する
    tar -czf "/work/rpmbuild/SOURCES/frr-${FRR_VERSION}.tar.gz" --transform "s#^frr-src-${FRR_VERSION}#frr-${FRR_VERSION}#" -C /work "frr-src-${FRR_VERSION}"
    # specファイルをRPMビルド用のディレクトリにコピーする
    cp -f "${specfile}" /work/rpmbuild/SPECS/frr.spec

    # FRRのrpmパッケージをビルドする
    rpmbuild -ba /work/rpmbuild/SPECS/frr.spec \
    --define "_topdir /work/rpmbuild" \
    --define "with_rpki 0" \
    --define "with_docs 0" \
    --define "version ${FRR_VERSION}"

    # ビルドされたrpmパッケージを /work/output にコピーする
    # /workは, ホスト側のディレクトリにマウントされている
    # dockerコンテナ内での作業ディレクトリとして, playbook側で
    # 指定することを前提としている。
    mkdir -p /work/output
    find /work/rpmbuild/RPMS -type f -name '*.rpm' -exec cp -f {} /work/output/ \;
}

#
# メイン処理
#
main(){

    # FRRのrpmパッケージをビルドする
    build_frr
}

main "$@"