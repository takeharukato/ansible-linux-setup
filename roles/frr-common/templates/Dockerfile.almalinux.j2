#
# FRR 構築コンテナイメージ生成用Dockerfile (AlmaLinux9.6環境)
#
# This file is generated by ansible.
{# 日付の取得 #}
# last update: {{ '%Y-%m-%d %H:%M:%S %Z' | strftime(ansible_date_time.epoch) }}
#
# rpmパッケージをビルドするためのAlmaLinux9.6のDockerイメージ
# コンテナイメージ作成時に開発環境を導入する

FROM almalinux:9.6

# パッケージ構築に必要なパッケージをインストールする
RUN dnf -y install \
      dnf-plugins-core \
      epel-release && \
    crb enable && \
    dnf -y install \
      git \
      rpm-build \
      make \
      gcc \
      gcc-c++ \
      autoconf \
      automake \
      libtool \
      bison \
      flex \
      byacc \
      cmake \
      gettext \
      json-c-devel \
      libcap-devel \
      libyang-devel \
      libpcap-devel \
      net-snmp-devel \
      pam-devel \
      pcre2-devel \
      readline-devel \
      systemd-devel \
      protobuf-c-devel \
      python3-devel \
      rpmdevtools \
      rpm-sign \
      redhat-rpm-config && \
    dnf clean all && \
    rm -rf /var/cache/dnf

# 作業ディレクトリを設定する
# 留意事項
# - templates/build-frr-rpm.sh.j2 内の変数workdirに合わせて設定すること
WORKDIR {{ frr_build_container_workdir }}
