+func TestPodKubeAPIAccessMutatorPlugin_Disabled(t *testing.T) {
+	defer util.SetFeatureGateDuringTest(t, featuregate.DefaultFeatureGate, featuregate.KubeAPIAccessSupport, true)()
+
+	pPod := tenantKubeAPIAccessPod("test", "cluster1-default", "123-456-789")
+	vPod := tenantKubeAPIAccessPod("test", "default", "000-456-789")
+
+	client := fake.NewSimpleClientset(
+		&corev1.Secret{
+			ObjectMeta: metav1.ObjectMeta{
+				Name:      "default-token-pkm85",
+				Namespace: "cluster1-default",
+				Annotations: map[string]string{
+					constants.LabelCluster:       "cluster1",
+					corev1.ServiceAccountNameKey: "default",
+					corev1.ServiceAccountUIDKey:  "7374a172-c35d-45b1-9c8e-bf5c5b614937",
+				},
+			},
+			Type: corev1.SecretTypeOpaque,
+		},
+		&corev1.ServiceAccount{
+			ObjectMeta: metav1.ObjectMeta{
+				Name:      "default",
+				Namespace: "cluster1-default",
+				UID:       "7374a172-c35d-45b1-9c8e-bf5c5b614937",
+			},
+		},
+	)
+
+	pl := &PodKubeAPIAccessMutatorPlugin{
+		client:       client,
+		generateName: func(prefix string) string { return prefix + "fixed" },
+		disable:      true,
+	}
+
+	beforeVolumeName := pPod.Spec.Volumes[0].Name
+	beforeSourceCount := len(pPod.Spec.Volumes[0].Projected.Sources)
+
+	if err := pl.Mutator()(&conversion.PodMutateCtx{ClusterName: "cluster1", PPod: pPod, VPod: vPod}); err != nil {
+		t.Fatalf("mutator failed: %v", err)
+	}
+
+	if pPod.Spec.Volumes[0].Name != beforeVolumeName {
+		t.Fatalf("volume name changed while disabled: got %q, want %q", pPod.Spec.Volumes[0].Name, beforeVolumeName)
+	}
+	if len(pPod.Spec.Volumes[0].Projected.Sources) != beforeSourceCount {
+		t.Fatalf("volume sources changed while disabled: got %d, want %d", len(pPod.Spec.Volumes[0].Projected.Sources), beforeSourceCount)
+	}
+	if pPod.Spec.Volumes[0].Projected.Sources[0].Secret != nil {
+		t.Fatalf("service account token projection unexpectedly replaced while disabled")
+	}
+}
