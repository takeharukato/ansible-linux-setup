+func TestShouldAutomount(t *testing.T) {
+	tests := []struct {
+		name      string
+		saValue   *bool
+		podValue  *bool
+		expected  bool
+	}{
+		{
+			name:     "pod explicitly false overrides serviceaccount true",
+			saValue:  pointer.BoolPtr(true),
+			podValue: pointer.BoolPtr(false),
+			expected: false,
+		},
+		{
+			name:     "pod explicitly true overrides serviceaccount false",
+			saValue:  pointer.BoolPtr(false),
+			podValue: pointer.BoolPtr(true),
+			expected: true,
+		},
+		{
+			name:     "serviceaccount false when pod unset",
+			saValue:  pointer.BoolPtr(false),
+			podValue: nil,
+			expected: false,
+		},
+		{
+			name:     "default true when both unset",
+			saValue:  nil,
+			podValue: nil,
+			expected: true,
+		},
+	}
+
+	for _, tt := range tests {
+		t.Run(tt.name, func(t *testing.T) {
+			sa := &corev1.ServiceAccount{AutomountServiceAccountToken: tt.saValue}
+			pod := &corev1.Pod{Spec: corev1.PodSpec{AutomountServiceAccountToken: tt.podValue}}
+			if got := shouldAutomount(sa, pod); got != tt.expected {
+				t.Fatalf("shouldAutomount() = %v, want %v", got, tt.expected)
+			}
+		})
+	}
+}
