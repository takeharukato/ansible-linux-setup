                  - key: node-role.kubernetes.io/control-plane
                    # 条件演算子。
                    operator: DoesNotExist
      # コンテナ定義。
      containers:
        # コンテナの指定。
        - name: vn-agent
          # コンテナイメージ。
          image: {{ virtualcluster_vn_agent_image|default("virtualcluster/vn-agent-amd64:latest", true) }}
          # 取得ポリシー。
          imagePullPolicy: {{ virtualcluster_image_pull_policy | default("Never", true) }}
          # コマンド指定と引数
          command:
            - {{ virtualcluster_vn_agent_cmd_path | default("/app", true) | trim | to_json }}
{% set vc_vn_agent_cert_dir = virtualcluster_vn_agent_cert_dir | default('', true) %}
{% set vc_vn_agent_pki_dir = virtualcluster_vn_agent_pki_dir | default(vc_vn_agent_cert_dir ~ '/pki', true) %}
{% set vc_vn_agent_has_cert_dir = (vc_vn_agent_cert_dir | length) > 0 %}
          args:
{% for vn_agent_arg in (virtualcluster_vn_agent_args | default([], true)) %}
{% set vc_is_cert_related_arg = ('--cert-dir=' in vn_agent_arg) or ('--kubelet-client-certificate=' in vn_agent_arg) or ('--kubelet-client-key=' in vn_agent_arg) %}
{% if vc_vn_agent_has_cert_dir or (not vc_is_cert_related_arg) %}
            - {{ vn_agent_arg |default([],true) | to_json }}
{% endif %}
{% endfor %}
          # セキュリティ設定。
          securityContext:
            # 特権モード。
            privileged: true
{% set vc_vn_agent_requests = virtualcluster_vn_agent_resource_requests | default({}, true) %}
{% set vc_vn_agent_limits = virtualcluster_vn_agent_resource_limits | default({}, true) %}
{% set vc_vn_agent_has_request_cpu = vc_vn_agent_requests.cpu is defined %}
{% set vc_vn_agent_has_request_memory = vc_vn_agent_requests.memory is defined %}
{% set vc_vn_agent_has_limit_cpu = vc_vn_agent_limits.cpu is defined %}
{% set vc_vn_agent_has_limit_memory = vc_vn_agent_limits.memory is defined %}
{% if vc_vn_agent_has_request_cpu or vc_vn_agent_has_request_memory or vc_vn_agent_has_limit_cpu or vc_vn_agent_has_limit_memory %}
          # リソース設定。
          resources:
{% if vc_vn_agent_has_request_cpu or vc_vn_agent_has_request_memory %}
            # リクエスト設定。
            requests:
{% if vc_vn_agent_has_request_cpu %}
              # CPUリクエスト。
              cpu: {{ vc_vn_agent_requests.cpu }}
{% endif %}
{% if vc_vn_agent_has_request_memory %}
              # メモリリクエスト。
              memory: {{ vc_vn_agent_requests.memory }}
{% endif %}
{% endif %}
{% if vc_vn_agent_has_limit_cpu or vc_vn_agent_has_limit_memory %}
            # リミット設定。
            limits:
{% if vc_vn_agent_has_limit_cpu %}
              # CPUリミット。
              cpu: {{ vc_vn_agent_limits.cpu }}
{% endif %}
{% if vc_vn_agent_has_limit_memory %}
              # メモリリミット。
              memory: {{ vc_vn_agent_limits.memory }}
{% endif %}
{% endif %}
{% endif %}
          # Podの終了時にコンテナの標準出力に書き込まれたログを取得するための設定(デフォルト値を明示)。
          terminationMessagePath: /dev/termination-log
          # Podの終了時にコンテナの標準出力に書き込まれたログを取得するための設定(デフォルト値を明示)。
          terminationMessagePolicy: File
          # ボリュームマウント。
          volumeMounts:
            # kubelet設定。
            - name: kubelet-config
              # マウントパス。
              mountPath: /etc/kubernetes
              # 読み取り専用フラグ。
              readOnly: true
            # kubeletクライアント証明書。
            - name: kubelet-client-cert
              # マウントパス。
              mountPath: {{ vc_vn_agent_pki_dir|default('/etc/vn-agent/pki', true) }}
              # 読み取り専用フラグ。
              readOnly: true
      # ボリューム定義。
      volumes:
        # kubelet設定。
        - name: kubelet-config
          # hostPath指定。
          hostPath:
            # ホスト側パス。
            path: /etc/kubernetes
            # パスタイプ。
            type: Directory
        - name: kubelet-client-cert
          # Secret指定。
          secret:
            # Secretのデフォルトモード(8進数:0644,オーナー:読み書き可能, グループ/その他:読み取り可能)。
            defaultMode: 420
            # Secret名。
            secretName: empty-kubelet-client
            # Secret未作成でもPod起動可能にする。
            optional: true
      # K8sクラスタのDNSサービスを優先的に使用(デフォルト値を明示)。
      dnsPolicy: ClusterFirst
      # ホストネットワーク使用。
      hostNetwork: true
      # Podの再起動ポリシー。停止したら自動的に起動(デフォルト値を明示)。
      restartPolicy: Always
      # スケジューラ名(デフォルト値を明示)。
      schedulerName: default-scheduler
      # セキュリティコンテキスト(デフォルト値を明示)。
      securityContext: {}
      # サービスアカウント名 (デフォルト値:defaultから変更)。
      serviceAccountName: vn-agent
      # Podの終了猶予時間(デフォルト値を明示)。
      terminationGracePeriodSeconds: 30
      # 許容条件
      tolerations:
        # 許容設定。
        - operator: "Exists"
  # DaemonSetのロールアウト戦略。
  updateStrategy:
    rollingUpdate:
      # ロールアウト時の最大追加Pod数。新規にPodを増やさずに既存Podを置き換えるよう設定。
      maxSurge: 0
      # ロールアウト時の最大停止Pod数。更新中に利用不可となることを許容するPod数の最大値。1Podまで許容する設定。
      maxUnavailable: 1
    # RollingUpdate戦略では, 一度に全停止して置き換えるのではなく, 新旧Podを共存させながら置き換える。
    type: RollingUpdate
