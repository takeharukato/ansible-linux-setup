#
# netshoot (ポートスキャナ削除版) Pod マニフェスト
#
# イメージ: {{ _image }}
# pullポリシー: {{ _pull_policy }}
#
apiVersion: v1
kind: Pod
metadata:
  name: {{ netshoot_k8s_pod_name }}
  namespace: {{ netshoot_k8s_namespace }}
  labels:
    app: {{ netshoot_k8s_pod_name }}
spec:
  containers:
    - name: netshoot
      image: {{ _image }}
      imagePullPolicy: {{ _pull_policy }}
      command:
        - /bin/bash
        - -c
        - "trap : TERM INT; sleep infinity & wait"
      securityContext:
        capabilities:
          add:
            - NET_ADMIN
            - NET_RAW
      resources:
        requests:
          cpu: "100m"
          memory: "128Mi"
        limits:
          cpu: "500m"
          memory: "512Mi"
  restartPolicy: Never
  hostNetwork: false
  dnsPolicy: ClusterFirst
