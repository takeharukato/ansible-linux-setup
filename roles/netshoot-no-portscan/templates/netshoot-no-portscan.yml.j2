{# netshootのKubernetesマニフェストテンプレート                                 #}
{#                                                                              #}
{# 変数:                                                                        #}
{#   netshoot_image_registry - ローカルレジストリのイメージURL         #}
{#     設定例: "registry1.local:5000/netshoot:v0.16"                           #}
{#     未設定または空文字の場合は, containerd に直接登録されたイメージを使用   #}
{#   netshoot_no_portscan_image       - containerd 直接登録時のイメージ名       #}
{#   netshoot_k8s_namespace           - 展開先 Namespace                        #}
{#   netshoot_k8s_pod_name            - Pod 名                                  #}
{# --- #}
{# イメージ参照先とpullポリシーをローカルレジストリ有無で切り替える            #}
{# ローカルレジストリが設定されている場合はそちらを使用し,                     #}
{# pullポリシーをAlwaysにする。                                                 #}
{# containerd 直接登録の場合はノード上に既存のイメージを使用するため          #}
{# pullポリシーをNeverにする。                                                  #}
{% if netshoot_image_registry | default('') | length > 0 %}
{% set _image = netshoot_image_registry + ":" + netshoot_no_portscan_version %}
{% set _pull_policy = "IfNotPresent" %}
{% else %}
{% set _image = netshoot_no_portscan_image %}
{% set _pull_policy = "Never" %}
{% endif %}
---
