#!/usr/bin/env bash
# -*- coding:utf-8 mode:bash -*-
#
# netshoot コンテナイメージを構築する
#
# This file is generated by ansible.
# last update: {{ '%Y-%m-%d %H:%M:%S %Z' | strftime(ansible_date_time.epoch) }}

set -euo pipefail

# 構築するイメージ名
image_name="{{ netshoot_no_portscan_image }}"
# Dockerfileが存在するディレクトリ
build_dir="{{ netshoot_build_dir }}"
# コンテナイメージ出力先ディレクトリ
output_dir="{{ netshoot_output_dir }}"
# コンテナイメージファイル名
output_file="${output_dir}/{{netshoot_no_portscan_image_file}}"
# ビルド時に使用するネットワークモード
# host を指定することで, ビルドコンテナがホストのDNS設定を引き継ぎ
# apk/apt による名前解決の失敗を防ぐ
build_network="{{ netshoot_docker_build_network }}"
# Dockerfileが存在するディレクトリを指定してコンテナイメージを構築する
docker build --network="${build_network}" -t "${image_name}" "${build_dir}"

# コンテナイメージをtar形式で出力する
docker save -o "${output_file}" "${image_name}"