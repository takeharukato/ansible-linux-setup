#!/usr/bin/env bash
# -*- coding:utf-8 mode:bash -*-
#
# Python 言語版 Kubernetes client のdebパッケージをビルドする
#
# This file is generated by ansible.
{# 日付の取得 #}
# last update: {{ '%Y-%m-%d %H:%M:%S %Z' | strftime(ansible_date_time.epoch) }}

set -euo pipefail

#
# 環境変数設定
#
: "${K8S_PY_CLIENT_VERSION_SPEC:?K8S_PY_CLIENT_VERSION_SPEC is required}"
: "${K8S_PY_CLIENT_DEB_PACKAGE_NAME:?K8S_PY_CLIENT_DEB_PACKAGE_NAME is required}"
: "${K8S_PY_CLIENT_INSTALL_DIR:?K8S_PY_CLIENT_INSTALL_DIR is required}"

#
# 作業ディレクトリの設定
#
workdir="{{ python_k8s_client_build_container_workdir }}"
outdir="${workdir}/output"
stage_dir="${workdir}/python-k8s-client-deb-stage"
pkgroot="${stage_dir}/root"
control_dir="${pkgroot}/DEBIAN"
venv_dir="${workdir}/venv"
package_version=""

#
# Python言語版 Kubernetes クライアントのオフラインキット構築処理
#
build_python_client(){
    local dir

    #
    # ステージングディレクトリの初期化
    #
    rm -rf "${stage_dir}"

    #
    # オフラインキット構築のためのディレクトリを作成
    #
    for dir in "${outdir}" \
                "${control_dir}" \
                "${pkgroot}${K8S_PY_CLIENT_INSTALL_DIR}"; do
        mkdir -p "${dir}"
    done

    #
    # Python仮想環境を作成し, Kubernetes clientをインストールする
    #
    venv_dir="${pkgroot}${K8S_PY_CLIENT_INSTALL_DIR}/venv"
    python3 -m venv --copies "${venv_dir}"
    "${venv_dir}/bin/pip" install --upgrade pip
    "${venv_dir}/bin/pip" install "kubernetes${K8S_PY_CLIENT_VERSION_SPEC}" packaging

    #
    # Kubernetes clientのバージョンを取得し, VERSIONファイルに書き込む
    #
    package_version="$("${venv_dir}/bin/python" -c 'import kubernetes; print(kubernetes.__version__)')"
    echo "${package_version}" > "${pkgroot}${K8S_PY_CLIENT_INSTALL_DIR}/VERSION"
}

#
# Python言語版 Kubernetes クライアントのdebパッケージを構築する
#
build_package(){
    local installed_size

    #
    # インストールサイズを取得
    #
    installed_size="$(du -ks "${pkgroot}" | awk '{print $1}')"

    #
    # debパッケージの制御ファイルを作成
    #
    cat > "${control_dir}/control" <<EOF
Package: ${K8S_PY_CLIENT_DEB_PACKAGE_NAME}
Version: ${package_version}-1
Section: devel
Priority: optional
Architecture: all
Maintainer: python-k8s-client-local builder <root@localhost>
Installed-Size: ${installed_size}
Description: Offline Python Kubernetes client ${package_version}
EOF

    #
    # debパッケージを生成する
    #
    dpkg-deb --build "${pkgroot}" "${outdir}/${K8S_PY_CLIENT_DEB_PACKAGE_NAME}_${package_version}-1_all.deb"
}

main(){

    # Python言語版 Kubernetes クライアントのオフラインキットを構築する
    build_python_client
    # debパッケージを構築する
    build_package
}

main "$@"