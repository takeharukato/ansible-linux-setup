#!/usr/bin/env bash
# -*- coding:utf-8 mode:bash -*-
#
# Python 言語版 Kubernetes client のdebパッケージをビルドする
#
# This file is generated by ansible.
{# 日付の取得 #}
# last update: {{ '%Y-%m-%d %H:%M:%S %Z' | strftime(ansible_date_time.epoch) }}

set -euo pipefail

#
# 環境変数設定
#
# - K8S_PY_CLIENT_VERSION_SPEC PEP440 形式のpythonバージョン指定
# - K8S_PY_CLIENT_RPM_PACKAGE_NAME Python 言語版 Kubernetes client のrpmパッケージ名
# - K8S_PY_CLIENT_PYTHON_VERSION 開発用Pythonの版数
#
: "${K8S_PY_CLIENT_VERSION_SPEC:?K8S_PY_CLIENT_VERSION_SPEC is required}"
: "${K8S_PY_CLIENT_DEB_PACKAGE_NAME:?K8S_PY_CLIENT_DEB_PACKAGE_NAME is required}"
: "${K8S_PY_CLIENT_PYTHON_VERSION:=}"

#
# 作業ディレクトリの設定
#
workdir="{{ python_k8s_client_build_container_workdir }}"
outdir="${workdir}/output"
stage_dir="${workdir}/python-k8s-client-deb-stage"
pkgroot="${stage_dir}/root"
control_dir="${pkgroot}/DEBIAN"
control_template_path="${workdir}/python-k8s-client.control"
stage_vendor_dir="${pkgroot}/usr/share/python-k8s-client/vendor"
target_python_cmd=""
stage_sitelib_dir=""
package_version=""

#
# Python言語版 Kubernetes クライアントのオフラインキット構築処理
#
build_python_client(){
    local dir
    local target_sitelib

    #
    # 開発用のpython版数をk8s_python_packages_versionで指定している場合は
    # 指定された版数のpythonインタプリタを用いる
    #
    if [[ -n "${K8S_PY_CLIENT_PYTHON_VERSION}" ]]; then
        target_python_cmd="/usr/bin/python${K8S_PY_CLIENT_PYTHON_VERSION}"
    else
        target_python_cmd="/usr/bin/python3"
    fi

    # pythonインタプリタの存在を確認
    if [[ ! -x "${target_python_cmd}" ]]; then
        echo "target python not found: ${target_python_cmd}" >&2
        return 1
    fi

    if ! "${target_python_cmd}" -m pip --version >/dev/null 2>&1; then
        "${target_python_cmd}" -m ensurepip --upgrade
    fi

    # pythonインタプリタのsite libディレクトリのパスを取得
    target_sitelib="$("${target_python_cmd}" -c 'import sysconfig; print(sysconfig.get_path("purelib"))')"
    if [[ -z "${target_sitelib}" ]]; then
        echo "failed to detect target python purelib path" >&2
        return 1
    fi
    stage_sitelib_dir="${pkgroot}${target_sitelib}"

    #
    # ステージングディレクトリの初期化
    #
    rm -rf "${stage_dir}"

    #
    # オフラインキット構築のためのディレクトリを作成
    #
    for dir in "${outdir}" \
                "${control_dir}" \
                "${stage_sitelib_dir}" \
                "${stage_vendor_dir}"; do
        mkdir -p "${dir}"
    done

    #
    # Kubernetes client本体をsystem Python向けsite-packages相当の配置先へ導入する
    #
    "${target_python_cmd}" -m pip install --no-cache-dir --no-compile --target "${stage_sitelib_dir}" --no-deps \
        "kubernetes${K8S_PY_CLIENT_VERSION_SPEC}"

    #
    # 外部依存をvendorディレクトリへ同梱し, system側依存と混在しないようにする
    #
    "${target_python_cmd}" -m pip install --no-cache-dir --no-compile --target "${stage_vendor_dir}" \
        "packaging" \
        "certifi" \
        "six" \
        "python-dateutil" \
        "urllib3" \
        "PyYAML" \
        "google-auth" \
        "websocket-client" \
        "requests" \
        "requests-oauthlib==1.3.1" \
        "oauthlib==3.2.2" \
        "durationpy>=0.7"

    #
    # vendor依存を探索パスの先頭に追加する
    #
    echo "import sys; sys.path.insert(0, '/usr/share/python-k8s-client/vendor')" > \
        "${stage_sitelib_dir}/python_k8s_client_vendor.pth"

    #
    # Kubernetes clientのバージョンを取得する
    #
    package_version="$(PYTHONPATH="${stage_vendor_dir}:${stage_sitelib_dir}" "${target_python_cmd}" -c 'import kubernetes; print(kubernetes.__version__)')"
}

#
# Python言語版 Kubernetes クライアントのdebパッケージを構築する
#
build_package(){
    local installed_size
    local control_path

    #
    # インストールサイズを取得
    #
    installed_size="$(du -ks "${pkgroot}" | awk '{print $1}')"
    control_path="${control_dir}/control"

    if [[ ! -f "${control_template_path}" ]]; then
        echo "control template not found: ${control_template_path}" >&2
        return 1
    fi

    #
    # debパッケージの制御ファイルをテンプレートから作成
    #
    cp -f "${control_template_path}" "${control_path}"
    sed -i "s|@K8S_PACKAGE_VERSION@|${package_version}|g" "${control_path}"
    sed -i "s|@K8S_INSTALLED_SIZE@|${installed_size}|g" "${control_path}"

    #
    # debパッケージを生成する
    #
    dpkg-deb --build "${pkgroot}" "${outdir}/${K8S_PY_CLIENT_DEB_PACKAGE_NAME}_${package_version}-1_all.deb"
}

main(){

    # Python言語版 Kubernetes クライアントのオフラインキットを構築する
    build_python_client
    # debパッケージを構築する
    build_package
}

main "$@"