#!/usr/bin/env bash
# -*- coding:utf-8 mode:bash -*-
#
# Python 言語版 Kubernetes client のrpmパッケージをビルドする
#
# This file is generated by ansible.
{# 日付の取得 #}
# last update: {{ '%Y-%m-%d %H:%M:%S %Z' | strftime(ansible_date_time.epoch) }}

set -euo pipefail

#
# 環境変数設定
#
: "${K8S_PY_CLIENT_VERSION_SPEC:?K8S_PY_CLIENT_VERSION_SPEC is required}"
: "${K8S_PY_CLIENT_RPM_PACKAGE_NAME:?K8S_PY_CLIENT_RPM_PACKAGE_NAME is required}"
: "${K8S_PY_CLIENT_INSTALL_DIR:?K8S_PY_CLIENT_INSTALL_DIR is required}"
: "${K8S_PY_CLIENT_RPM_ARCH:?K8S_PY_CLIENT_RPM_ARCH is required}"

#
# 作業ディレクトリの設定
#
workdir="{{ python_k8s_client_build_container_workdir }}"
outdir="${workdir}/output"
rpmbuild_dir="${workdir}/rpmbuild"
venv_dir="${workdir}/venv-resolve"
package_version=""

#
# Python言語版 Kubernetes クライアントのオフラインキット構築処理
#
build_python_client(){

    #
    # venvディレクトリの初期化
    #
    rm -rf "${venv_dir}"
    python3 -m venv --copies "${venv_dir}"

    # venv内のpipをアップグレード
    "${venv_dir}/bin/pip" install --upgrade pip
    # pipを用いてKubernetes clientをインストール
    "${venv_dir}/bin/pip" install "kubernetes${K8S_PY_CLIENT_VERSION_SPEC}" packaging
    # Kubernetes clientのバージョンを取得し, package_version変数に格納する
    package_version="$("${venv_dir}/bin/python" -c 'import kubernetes; print(kubernetes.__version__)')"
}

#
# Python言語版 Kubernetes クライアントのrpmパッケージを構築する
#
build_rpm(){
    local dir

    #
    # ステージングディレクトリの初期化
    #
    rm -rf "${rpmbuild_dir}"

    #
    # rpmパッケージ構築のためのディレクトリを作成
    #
    for dir in "${outdir}" \
                "${rpmbuild_dir}/SOURCES" \
                "${rpmbuild_dir}/SPECS" \
                "${rpmbuild_dir}/BUILD" \
                "${rpmbuild_dir}/BUILDROOT" \
                "${rpmbuild_dir}/RPMS" \
                "${rpmbuild_dir}/SRPMS"; do
        mkdir -p "${dir}"
    done

    # rpmパッケージのspecファイルを作成する
    cat > "${rpmbuild_dir}/SPECS/${K8S_PY_CLIENT_RPM_PACKAGE_NAME}.spec" <<EOF
Name:           ${K8S_PY_CLIENT_RPM_PACKAGE_NAME}
Version:        ${package_version}
Release:        1%{?dist}
Summary:        Offline Python Kubernetes client
License:        Apache-2.0
BuildArch:      ${K8S_PY_CLIENT_RPM_ARCH}
# venv includes arch-dependent binary wheels and must not be stripped/debuginfo processed.
%global debug_package %{nil}
%global __strip /bin/true

%description
Offline Python Kubernetes client ${package_version}

%prep


%build

%install
rm -rf %{buildroot}
mkdir -p %{buildroot}${K8S_PY_CLIENT_INSTALL_DIR}
python3 -m venv --copies %{buildroot}${K8S_PY_CLIENT_INSTALL_DIR}/venv
%{buildroot}${K8S_PY_CLIENT_INSTALL_DIR}/venv/bin/pip install --upgrade pip
%{buildroot}${K8S_PY_CLIENT_INSTALL_DIR}/venv/bin/pip install kubernetes==${package_version} packaging
# Remove temporary buildroot prefix from generated script shebangs/activate files.
buildroot_path="%{buildroot}"
if grep -RIl "\${buildroot_path}" %{buildroot}${K8S_PY_CLIENT_INSTALL_DIR}/venv >/dev/null 2>&1; then
    grep -RIl "\${buildroot_path}" %{buildroot}${K8S_PY_CLIENT_INSTALL_DIR}/venv \
        | xargs sed -i "s#\${buildroot_path}##g"
fi
echo ${package_version} > %{buildroot}${K8S_PY_CLIENT_INSTALL_DIR}/VERSION

%files
${K8S_PY_CLIENT_INSTALL_DIR}/venv
${K8S_PY_CLIENT_INSTALL_DIR}/VERSION
EOF

    #
    # rpmパッケージを作成する
    #
    rpmbuild -bb "${rpmbuild_dir}/SPECS/${K8S_PY_CLIENT_RPM_PACKAGE_NAME}.spec" --define "_topdir ${rpmbuild_dir}"

    # ビルドされたrpmパッケージを /work/output にコピーする
    find "${rpmbuild_dir}/RPMS" -type f -name '*.rpm' -exec cp -f {} "${outdir}/" \;
}

#
# メイン処理
#
main(){

    # Python言語版 Kubernetes クライアントのオフラインキットを構築する
    build_python_client
    # rpmパッケージを構築する
    build_rpm
}

main "$@"