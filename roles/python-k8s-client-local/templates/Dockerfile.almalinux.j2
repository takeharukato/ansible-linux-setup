#
# Python 言語版 Kubernetes client 構築コンテナイメージ生成用Dockerfile (AlmaLinux9.6環境)
#

# This file is generated by ansible.
{# 日付の取得 #}
# last update: {{ '%Y-%m-%d %H:%M:%S %Z' | strftime(ansible_date_time.epoch) }}

FROM almalinux:9.6

#
# 開発環境の導入
# 開発用のpython版数をk8s_python_packages_versionで指定している場合は,
# 当該版数のpythonインタプリタ, 開発パッケージ, pipも導入する
#
RUN dnf -y install --setopt=install_weak_deps=False \
    curl-minimal \
    python3 \
    python3-devel \
    python3-pip \
{% if (k8s_python_packages_version is defined) and ((k8s_python_packages_version | string | trim | length) > 0) %}
    python{{ k8s_python_packages_version }} \
    python{{ k8s_python_packages_version }}-devel \
    python{{ k8s_python_packages_version }}-pip \
{% endif %}
    python3-setuptools \
    python3-wheel \
    pyproject-rpm-macros \
    python3-rpm-macros \
    git-core \
    rpm-build \
    redhat-rpm-config \
    tar \
    gzip \
    shadow-utils \
    bash && \
    dnf clean all && \
    rm -rf /var/cache/dnf

# 作業ディレクトリの設定
# 留意事項:
#  - templates/build-python-k8s-client-rpm.sh.j2 内の変数workdirに合わせて設定すること
#
WORKDIR {{ python_k8s_client_build_container_workdir }}