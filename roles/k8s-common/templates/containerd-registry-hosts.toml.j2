#
#  -*- coding:utf-8 mode:toml -*-
# This file is generated by ansible.
# last update: {{ '%Y-%m-%d %H:%M:%S %Z' | strftime(ansible_date_time.epoch) }}
#
{% if ( item.endpoint|default('', true) | length ) > 0 %}
#
# {{ item.endpoint }}用のコンテナレジストリ設定
#
{% set endpoint = item.endpoint %}
{% set default_scheme = ((k8s_containerd_registry_plain_http | default(true) | bool) | ternary('http', 'https')) %}
{% set scheme = (item.scheme | default(default_scheme, true) | lower) %}
{% set skip_verify = (item.skip_verify | default((scheme != 'https'), true)) %}
# コンテナレジストリサーバ
server = "{{ scheme }}://{{ endpoint }}"

[host."{{ scheme }}://{{ endpoint }}"]
  capabilities = ["pull", "resolve", "push"]
  skip_verify = {{ (skip_verify | bool) | ternary('true', 'false') }}
{% endif %}