#!/usr/bin/env bash
# -*- coding:utf-8 mode:bash -*-
#
# Goのrpmパッケージをビルドする
#
# 実行時パラメタ環境変数
#  - GO_VERSION: ビルド対象のGo版数
#  - GO_BASE_URL: Go tarball取得先のベースURL
#  - GO_ARCH: Go tarball用アーキテクチャ名
#  - GO_RPM_ARCH: rpmパッケージ用アーキテクチャ名
#  - GO_PACKAGE_NAME: 生成するrpmパッケージ名
#  - GO_INSTALL_DIR: Goインストール先ディレクトリ
#  - GO_PROFILE_SCRIPT: profile.dスクリプト配置先
#
# This file is generated by ansible.
{# 日付の取得 #}
# last update: {{ '%Y-%m-%d %H:%M:%S %Z' | strftime(ansible_date_time.epoch) }}

set -euo pipefail

#
# 環境変数取得
#

: "${GO_VERSION:?GO_VERSION is required}"
: "${GO_BASE_URL:?GO_BASE_URL is required}"
: "${GO_ARCH:?GO_ARCH is required}"
: "${GO_RPM_ARCH:?GO_RPM_ARCH is required}"
: "${GO_PACKAGE_NAME:?GO_PACKAGE_NAME is required}"
: "${GO_INSTALL_DIR:?GO_INSTALL_DIR is required}"
: "${GO_PROFILE_SCRIPT:?GO_PROFILE_SCRIPT is required}"

#
# 作業ディレクトリの設定
#
# 留意事項
# - workdirは, Dockerfile.almalinux内のWORKDIRと合わせること
#
workdir="{{ go_build_container_workdir }}"
outdir="${workdir}/output"
rpmbuild_dir="${workdir}/rpmbuild"
source_tarball="go${GO_VERSION}.linux-${GO_ARCH}.tar.gz"
profile_dir="$(dirname "${GO_PROFILE_SCRIPT}")"

#
# Goのソースアーカイブを取得して展開し, rpmパッケージをビルドする
#
build_go_lang(){
    local tarball
    local dir

    #
    # rpm構築ディレクトリを初期化
    # - "${rpmbuild_dir:?}/"* は,
    #   ${rpmbuild_dir}配下の全てのファイル・ディレクトリを削除することを意味する。
    #   "${rpmbuild_dir:?}/*"とすると, *が展開されないことに注意。
    #
    # - :?をつけることで、変数が空の場合に
    #   rmコマンドが誤ってルートディレクトリを削除することを防ぐ
    if [ -d "${rpmbuild_dir}" ]; then
        rm -rf "${rpmbuild_dir:?}/"*
    fi
    mkdir -p "${rpmbuild_dir}"

    #
    # ディレクトリ群を作成
    #
    for dir in "${outdir}" \
                "${rpmbuild_dir}/SOURCES" \
                "${rpmbuild_dir}/SPECS" \
                "${rpmbuild_dir}/BUILD" \
                "${rpmbuild_dir}/BUILDROOT" \
                "${rpmbuild_dir}/RPMS" \
                "${rpmbuild_dir}/SRPMS"; do
        mkdir -p "${dir}"
    done

    #
    # Goのソースアーカイブを取得
    #
    curl -fsSL "${GO_BASE_URL}/${source_tarball}" -o "${rpmbuild_dir}/SOURCES/${source_tarball}"

    #
    # rpmパッケージのspecファイルを作成
    #
    # 留意事項
    #   rpmパッケージの場合, %installセクションで
    #   /etc/profile.d/go.shを作成するため, specファイル内で
    #   profile.dスクリプトの内容を記述する
    #
    cat > "${rpmbuild_dir}/SPECS/${GO_PACKAGE_NAME}.spec" <<EOF
Name:           ${GO_PACKAGE_NAME}
Version:        ${GO_VERSION}
Release:        1%{?dist}
Summary:        Go language toolchain
License:        BSD-3-Clause
URL:            https://go.dev/
Source0:        ${source_tarball}
BuildArch:      ${GO_RPM_ARCH}
# Go tarball includes cross-arch .syso/.obj files under src/, disable strip to avoid format errors.
%global __strip /bin/true
# Exclude Go test fixtures/testdata from auto dependency/provide generation.
# These paths can include sample binaries and shared objects that are not runtime
# requirements of the Go toolchain itself.
%global __requires_exclude_from ^/usr/local/go/(test/.*|src/test/.*|src/.*/testdata/.*)$
%global __provides_exclude_from ^/usr/local/go/(test/.*|src/test/.*|src/.*/testdata/.*)$

%description
Go language toolchain ${GO_VERSION}

%prep

%build

%install
rm -rf %{buildroot}
mkdir -p %{buildroot}/usr/local
mkdir -p %{buildroot}/usr/local/bin
mkdir -p %{buildroot}${profile_dir}
tar -xzf %{_sourcedir}/${source_tarball} -C %{buildroot}/usr/local
ln -sfn ${GO_INSTALL_DIR}/bin/go %{buildroot}/usr/local/bin/go
cat > %{buildroot}${GO_PROFILE_SCRIPT} <<'EOS'
export GOROOT=/usr/local/go
export PATH=/usr/local/go/bin:\$PATH
EOS

%files
/usr/local/go
/usr/local/bin/go
${GO_PROFILE_SCRIPT}
EOF

    #
    # rpmパッケージをビルド
    #
    rpmbuild -bb "${rpmbuild_dir}/SPECS/${GO_PACKAGE_NAME}.spec" --define "_topdir ${rpmbuild_dir}"

    # 生成したrpmパッケージを出力ディレクトリにコピー
    find "${rpmbuild_dir}/RPMS" -type f -name '*.rpm' -exec cp -f {} "${outdir}/" \;
}


#
# メイン処理
#
main(){
    build_go_lang
}

main "$@"
