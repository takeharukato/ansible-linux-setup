#!/usr/bin/env bash
# -*- coding:utf-8 mode:bash -*-
#
# Goのdebパッケージをビルドする
#
# 実行時パラメタ環境変数
#  - GO_VERSION: ビルド対象のGo版数
#  - GO_BASE_URL: Go tarball取得先のベースURL
#  - GO_ARCH: Go tarball用アーキテクチャ名
#  - GO_DEB_ARCH: debパッケージ用アーキテクチャ名
#  - GO_PACKAGE_NAME: 生成するdebパッケージ名
#  - GO_INSTALL_DIR: Goインストール先ディレクトリ
#  - GO_PROFILE_SCRIPT: profile.dスクリプト配置先
#
# This file is generated by ansible.
{# 日付の取得 #}
# last update: {{ '%Y-%m-%d %H:%M:%S %Z' | strftime(ansible_date_time.epoch) }}

set -euo pipefail

#
# 環境変数取得
#

: "${GO_VERSION:?GO_VERSION is required}"
: "${GO_BASE_URL:?GO_BASE_URL is required}"
: "${GO_ARCH:?GO_ARCH is required}"
: "${GO_DEB_ARCH:?GO_DEB_ARCH is required}"
: "${GO_PACKAGE_NAME:?GO_PACKAGE_NAME is required}"
: "${GO_INSTALL_DIR:?GO_INSTALL_DIR is required}"
: "${GO_PROFILE_SCRIPT:?GO_PROFILE_SCRIPT is required}"

#
# 作業ディレクトリの設定
#
# 留意事項
# - workdirは, Dockerfile.ubuntu内のWORKDIRと合わせること
#
workdir="{{ go_build_container_workdir }}"
outdir="${workdir}/output"
stage_dir="${workdir}/go-deb-stage"
pkgroot="${stage_dir}/root"
control_dir="${pkgroot}/DEBIAN"
install_parent="$(dirname "${GO_INSTALL_DIR}")"
profile_dir="$(dirname "${GO_PROFILE_SCRIPT}")"

#
# Goのソースアーカイブを取得して展開し, debパッケージをビルドする
#
build_go_lang(){
    local tarball
    local dir

    #
    # ステージングディレクトリの初期化
    # - "${stage_dir:?}/"* は,
    #   ${stage_dir}配下の全てのファイル・ディレクトリを削除することを意味する。
    #   "${stage_dir:?}/*"とすると, *が展開されないことに注意。
    #
    # - :?をつけることで、変数が空の場合に
    #   rmコマンドが誤ってルートディレクトリを削除することを防ぐ
    if [ -d "${stage_dir}" ]; then
        rm -rf "${stage_dir:?}/"*
    fi
    mkdir -p "${stage_dir}"

    #
    # ディレクトリ群を作成
    # - ステージング初期化後に再作成する
    #
    for dir in "${outdir}" \
                "${control_dir}" \
                "${pkgroot}${install_parent}" \
                "${pkgroot}/usr/local/bin" \
                "${pkgroot}${profile_dir}"; do
        mkdir -p "${dir}"
    done


    #
    # Goのソースアーカイブの取得と展開
    #

    # Goのソースアーカイブを取得
    tarball="${workdir}/go${GO_VERSION}.linux-${GO_ARCH}.tar.gz"
    curl -fsSL "${GO_BASE_URL}/go${GO_VERSION}.linux-${GO_ARCH}.tar.gz" -o "${tarball}"

    # Goのソースアーカイブを展開
    tar -xzf "${tarball}" -C "${pkgroot}${install_parent}"

    # Goコマンドのシンボリックリンクを作成
    ln -sfn "${GO_INSTALL_DIR}/bin/go" "${pkgroot}/usr/local/bin/go"

    #
    # Goのprofile.dスクリプトを作成
    #
    cat > "${pkgroot}${GO_PROFILE_SCRIPT}" <<'EOF'
export GOROOT=/usr/local/go
export PATH=/usr/local/go/bin:$PATH
EOF
}

build_package(){
    local installed_size

    # 導入ファイルサイズを計算
    installed_size="$(du -ks "${pkgroot}" | awk '{print $1}')"

    # debパッケージの制御ファイルを作成
    cat > "${control_dir}/control" <<EOF
Package: ${GO_PACKAGE_NAME}
Version: ${GO_VERSION}-1
Section: devel
Priority: optional
Architecture: ${GO_DEB_ARCH}
Maintainer: go-lang-local builder <root@localhost>
Installed-Size: ${installed_size}
Description: Go language toolchain ${GO_VERSION}
EOF

    # debパッケージをビルド
    dpkg-deb --build "${pkgroot}" "${outdir}/${GO_PACKAGE_NAME}_${GO_VERSION}-1_${GO_DEB_ARCH}.deb"
}

#
# メイン処理
#
main(){
    build_go_lang
    build_package
}

main "$@"
