{# 日付の取得 #}
# last update: {{ '%Y-%m-%d %H:%M:%S %Z' | strftime(ansible_date_time.epoch) }}
#
# [VirtualCluster - Enabling Kubernetes Hard Multi-tenancy](https://github.com/kubernetes-retired/cluster-api-provider-nested/tree/main/virtualcluster)
# の仮想クラスタ(テナント)内で動作するCoreDNSのコンテナイメージを作成するDockerfile
#
# CoreDNS (Kubernetes のサービス名からIPアドレスとポートの組を返すサービス) を
# VirtualCluster - Enabling Kubernetes Hard Multi-tenancy の仮想クラスタ(テナント)内で
# 動作させるためのパッチを当て, コンテナイメージを作成するDockerfile
# マルチステージビルド (https://docs.docker.jp/develop/develop-images/multistage-build.html)
# 形式のDockerfileとして構成されている
#
# [1] 構築ステージ (builderステージ)
#   1. ビルドコンテキストに配置済みのcorednsのソースコードをコンテナ内へコピーし,
#      VirtualCluster - Enabling Kubernetes Hard Multi-tenancy の仮想クラスタ(テナント)内で動作させるためのパッチを当てる
#   2. corednsのソースコードをビルドし, 実行可能ファイルを生成する
# [2] コンテナイメージ生成ステージ
#   1. 構築ステージで生成した実行可能ファイルをコンテナイメージにコピーする
#
# 変数定義
#
# GO_VERSION: Go言語のバージョン
ARG GO_VERSION={{ k8s_vc_tenant_dns_go_version|default('1.22', true) }}
# ALPINE_VERSION: Alpine Linux環境(コンパイル環境)のバージョン
ARG ALPINE_VERSION={{ k8s_vc_tenant_dns_alpine_version|default('3.20', true) }}
# PATCH_FILE: CoreDNSのソースコードに当てるパッチファイル名
ARG PATCH_FILE=vc-tenant-dns-support.patch

#
# CoreDNSのソースコードをビルドする際のパラメタ
#
# PARAM_CGO_ENABLED: cgo(C言語関数呼び出し)を無効化
# (コンテナイメージのサイズを小さくするため)
ARG PARAM_CGO_ENABLED=0
# PARAM_GOOS: ビルド対象のOS (Linux)
ARG PARAM_GOOS=linux
# PARAM_GOARCH: ビルド対象のCPUアーキテクチャ (amd64)
ARG PARAM_GOARCH=amd64

#
# 構築ステージ
#
# alpine(軽量Linuxコンテナ)版のGo言語環境のDockerイメージを
# 使用してcorednsのソースコードをビルドする
# 参考) https://hub.docker.com/_/golang/
#

# 後続のコンテナイメージ生成ステージで, 構築ステージで
# 生成した実行可能ファイルをコピーする際に構築ステージの成果物を
# 参照するため, AS builderをつけて, 構築ステージにbuilderという
# 名前をつける
FROM golang:${GO_VERSION}-alpine${ALPINE_VERSION} AS builder

#
# builderステージで使用する変数を宣言
#
ARG PATCH_FILE
ARG PARAM_CGO_ENABLED
ARG PARAM_GOOS
ARG PARAM_GOARCH

# 作業ディレクトリを/workに設定
# これ以降は, 相対パスでファイル操作時は/workを基準にしたパスとなる
WORKDIR /work

# 構築ステージで必要なパッケージをインストール
RUN apk add --no-cache bash ca-certificates git patch

# パッチファイルをコンテナ内の/patchesディレクトリにコピー
RUN mkdir -p /patches
COPY ${PATCH_FILE} /patches/${PATCH_FILE}

# ビルドコンテキストに展開済みのCoreDNSソースコードをコンテナ内へコピー
COPY src /src

# 作業ディレクトリを/srcに変更
# これ以降は, 相対パスでファイル操作時は/srcを基準にしたパスとなる
WORKDIR /src

RUN git apply /patches/${PATCH_FILE}

RUN CGO_ENABLED=${PARAM_CGO_ENABLED} GOOS=${PARAM_GOOS} GOARCH=${PARAM_GOARCH} \
    go build -trimpath -ldflags="-s -w" -o /out/coredns .

#
# コンテナイメージ生成ステージ (名前なし)
#
FROM alpine:${ALPINE_VERSION}

# 依存パッケージを導入
RUN apk add --no-cache ca-certificates

# builderステージで生成した成果物を/out/corednsとして保存
COPY --from=builder /out/coredns /coredns

# コンテナ内の以下のポートを使用する
# - TCP {{ k8s_vc_tenant_dns_port_dns }}番ポート   (DNS標準ポート, TCPによるサービス検出に使用)
# - UDP {{ k8s_vc_tenant_dns_port_dns }}番ポート   (DNS標準ポート, UDPによるサービス検出に使用)
# - TCP {{ k8s_vc_tenant_dns_port_metrics }}ポート   (prometheus プラグイン用ポート 稼働状況やDNS問い合わせ数などの監視指標を取得)
# - TCP {{ k8s_vc_tenant_dns_port_health }}番ポート (health 用ポート CoreDNSプロセスが動作していることを確認)
# - TCP {{ k8s_vc_tenant_dns_port_ready }}番ポート (ready 用ポート CoreDNSが問い合わせを処理できる状態であることを確認)
EXPOSE {{ k8s_vc_tenant_dns_port_dns }}/tcp {{ k8s_vc_tenant_dns_port_dns }}/udp {{ k8s_vc_tenant_dns_port_metrics }}/tcp {{ k8s_vc_tenant_dns_port_health }}/tcp {{ k8s_vc_tenant_dns_port_ready }}/tcp

# /corednsをコンテナイメージのエントリポイントとして扱う
ENTRYPOINT ["/coredns"]
