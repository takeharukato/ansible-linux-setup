#
#  -*- coding:utf-8 mode:bash -*-
# This file is generated by ansible.
{% if (k8s_vc_tenant_dns_image_registry | default('', true) | trim | length) > 0 %}
{% set _image = k8s_vc_tenant_dns_image_registry + ":" + k8s_vc_tenant_dns_version %}
{% set _pull_policy = "IfNotPresent" %}
{% else %}
{% set _image = k8s_vc_tenant_dns_image %}
{% set _pull_policy = "Never" %}
{% endif %}
{# 日付の取得 #}
# last update: {{ '%Y-%m-%d %H:%M:%S %Z' | strftime(ansible_date_time.epoch) }}

#
# テナント内用CoreDNSコンテナのmanifestファイル
#
---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: coredns
  namespace: kube-system
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: system:coredns
rules:
  - apiGroups:
      - ""
    resources:
      - endpoints
      - services
      - pods
      - namespaces
    verbs:
      - list
      - watch
  - apiGroups:
      - discovery.k8s.io
    resources:
      - endpointslices
    verbs:
      - list
      - watch
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: system:coredns
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: system:coredns
subjects:
  - kind: ServiceAccount
    name: coredns
    namespace: kube-system
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: coredns
  namespace: kube-system
data:
  Corefile: |
    .:{{ k8s_vc_tenant_dns_port_dns }} {
      errors
      health {
        lameduck 5s
      }
      ready
      kubernetes cluster.local in-addr.arpa ip6.arpa {
        kubeconfig /etc/coredns/kubeconfig
        pods insecure
        fallthrough in-addr.arpa ip6.arpa
        ttl 30
      }
      prometheus :{{ k8s_vc_tenant_dns_port_metrics }}
      forward . /etc/resolv.conf {
        max_concurrent 1000
      }
      cache 30
      loop
      reload
      loadbalance
    }
  kubeconfig: |
{{ k8s_vc_tenant_dns_admin_kubeconfig | indent(4, true) }}
---
apiVersion: v1
kind: Service
metadata:
  name: kube-dns
  namespace: kube-system
  annotations:
    prometheus.io/port: "{{ k8s_vc_tenant_dns_port_metrics }}"
    prometheus.io/scrape: "true"
  labels:
    k8s-app: kube-dns
    kubernetes.io/name: "CoreDNS"
spec:
  selector:
    k8s-app: kube-dns
  ports:
    - name: dns
      port: {{ k8s_vc_tenant_dns_port_dns }}
      protocol: UDP
    - name: dns-tcp
      port: {{ k8s_vc_tenant_dns_port_dns }}
      protocol: TCP
    - name: metrics
      port: {{ k8s_vc_tenant_dns_port_metrics }}
      protocol: TCP
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: coredns
  namespace: kube-system
  labels:
    k8s-app: kube-dns
    kubernetes.io/name: "CoreDNS"
spec:
  replicas: 1
  strategy:
    type: RollingUpdate
    rollingUpdate:
      maxUnavailable: 1
  selector:
    matchLabels:
      k8s-app: kube-dns
  template:
    metadata:
      labels:
        k8s-app: kube-dns
    spec:
      # Avoid inheriting super-cluster Service env vars into the backing Pod.
      enableServiceLinks: false
      dnsPolicy: Default
      securityContext:
        seccompProfile:
          type: RuntimeDefault
      serviceAccountName: coredns
      affinity:
        podAntiAffinity:
          preferredDuringSchedulingIgnoredDuringExecution:
            - weight: 100
              podAffinityTerm:
                labelSelector:
                  matchExpressions:
                    - key: k8s-app
                      operator: In
                      values:
                        - kube-dns
                topologyKey: kubernetes.io/hostname
      tolerations:
        - key: "CriticalAddonsOnly"
          operator: "Exists"
      nodeSelector:
        kubernetes.io/os: linux
      containers:
        - name: coredns
          image: {{ _image }}
          imagePullPolicy: {{ _pull_policy }}
          args:
            - "-conf"
            - "/etc/coredns/Corefile"
          resources:
            requests:
              cpu: 100m
              memory: 70Mi
            limits:
              memory: 170Mi
          volumeMounts:
            - name: config-volume
              mountPath: /etc/coredns
              readOnly: true
          ports:
            - containerPort: {{ k8s_vc_tenant_dns_port_dns }}
              name: dns
              protocol: UDP
            - containerPort: {{ k8s_vc_tenant_dns_port_dns }}
              name: dns-tcp
              protocol: TCP
            - containerPort: {{ k8s_vc_tenant_dns_port_metrics }}
              name: metrics
              protocol: TCP
          livenessProbe:
            httpGet:
              path: /health
              port: {{ k8s_vc_tenant_dns_port_health }}
              scheme: HTTP
            initialDelaySeconds: 60
            timeoutSeconds: 5
            successThreshold: 1
            failureThreshold: 5
          readinessProbe:
            httpGet:
              path: /ready
              port: {{ k8s_vc_tenant_dns_port_ready }}
              scheme: HTTP
            initialDelaySeconds: 5
            periodSeconds: 5
            timeoutSeconds: 3
            successThreshold: 1
            failureThreshold: 12
          securityContext:
            allowPrivilegeEscalation: false
            readOnlyRootFilesystem: true
            capabilities:
              add:
                - NET_BIND_SERVICE
              drop:
                - ALL
          env:
            - name: KUBERNETES_SERVICE_HOST
              value: kubernetes
      volumes:
        - name: config-volume
          configMap:
            name: coredns
            items:
              - key: Corefile
                path: Corefile
              - key: kubeconfig
                path: kubeconfig
