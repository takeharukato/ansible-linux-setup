#
# Go 言語版 Kubernetes client 構築コンテナイメージ生成用Dockerfile (Ubuntu24.04環境)
#

# This file is generated by ansible.
{# 日付の取得 #}
# last update: {{ '%Y-%m-%d %H:%M:%S %Z' | strftime(ansible_date_time.epoch) }}

FROM ubuntu:24.04

# DEBIAN_FRONTEND=noninteractiveを設定することで,
# apt-getコマンド実行時に対話的な入力を求められることを防ぐ
ENV DEBIAN_FRONTEND=noninteractive

# パッケージ構築に必要なパッケージをインストールする
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      ca-certificates \
      golang-go \
      dpkg-dev \
      tar \
      xz-utils \
      git && \
    rm -rf /var/lib/apt/lists/*

#
# 作業ディレクトリ設定
#
# 留意事項
# - templates/build-k8s-client-go-deb.sh.j2 内の変数workdirに合わせて設定すること
WORKDIR {{ go_k8s_client_build_container_workdir }}