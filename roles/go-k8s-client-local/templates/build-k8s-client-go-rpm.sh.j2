#!/usr/bin/env bash
# -*- coding:utf-8 mode:bash -*-
#
# Go 言語版 Kubernetes client のrpmパッケージをビルドする
#
# 実行時パラメタ環境変数
#  - K8S_CLIENT_GO_VERSION: ビルド対象の client-go 版数 (vX.Y.Z)
#  - K8S_CLIENT_MODULE_DOMAIN: go module domain
#  - K8S_CLIENT_RPM_PACKAGE_NAME: 生成するrpmパッケージ名
#  - K8S_CLIENT_INSTALL_DIR: オフラインキット導入先
#
# This file is generated by ansible.
{# 日付の取得 #}
# last update: {{ '%Y-%m-%d %H:%M:%S %Z' | strftime(ansible_date_time.epoch) }}

set -euo pipefail

#
# 環境変数設定
#
: "${K8S_CLIENT_GO_VERSION:?K8S_CLIENT_GO_VERSION is required}"
: "${K8S_CLIENT_MODULE_DOMAIN:?K8S_CLIENT_MODULE_DOMAIN is required}"
: "${K8S_CLIENT_RPM_PACKAGE_NAME:?K8S_CLIENT_RPM_PACKAGE_NAME is required}"
: "${K8S_CLIENT_INSTALL_DIR:?K8S_CLIENT_INSTALL_DIR is required}"

#
# 作業ディレクトリの設定
#
workdir="{{ go_k8s_client_build_container_workdir }}"
outdir="${workdir}/output"
rpmbuild_dir="${workdir}/rpmbuild"
module_dir="${workdir}/module"
package_version="${K8S_CLIENT_GO_VERSION#v}"
module_name="${K8S_CLIENT_MODULE_DOMAIN}/k8s-devel-client-go"

#
# Go言語版 Kubernetes クライアントのオフラインキット構築処理
#
build_package(){
    local dir

    #
    # ステージングディレクトリの初期化
    #
    if [ -d "${rpmbuild_dir}" ]; then
        rm -rf "${rpmbuild_dir:?}/"*
    fi
    mkdir -p "${rpmbuild_dir}"

    #
    # モジュールディレクトリの初期化
    #
    if [ -d "${module_dir}" ]; then
        rm -rf "${module_dir:?}/"*
    else
        mkdir -p "${module_dir}"
    fi

    #
    # オフラインキット構築のためのディレクトリを作成
    #
    for dir in "${outdir}" \
                "${rpmbuild_dir}/SOURCES" \
                "${rpmbuild_dir}/SPECS" \
                "${rpmbuild_dir}/BUILD" \
                "${rpmbuild_dir}/BUILDROOT" \
                "${rpmbuild_dir}/RPMS" \
                "${rpmbuild_dir}/SRPMS"; do
        mkdir -p "${dir}"
    done

    #
    # Kubernetes クライアントモジュールを構築し, パッケージ
    # 生成時のステージングディレクトリにコピーする
    #
    cd "${module_dir}"
    go mod init "${module_name}"
    go get "k8s.io/client-go@${K8S_CLIENT_GO_VERSION}"
    go mod vendor

    #
    # ステージングディレクトリにオフラインキットをコピーする
    #
    mkdir -p "${rpmbuild_dir}/SOURCES/k8s-client-kit"
    cp -f "${module_dir}/go.mod" "${rpmbuild_dir}/SOURCES/k8s-client-kit/go.mod"
    cp -f "${module_dir}/go.sum" "${rpmbuild_dir}/SOURCES/k8s-client-kit/go.sum"
    cp -a "${module_dir}/vendor" "${rpmbuild_dir}/SOURCES/k8s-client-kit/vendor"

    #
    # オフラインキットのtar.gz形式アーカイブを作成する
    #
    tar -czf "${rpmbuild_dir}/SOURCES/k8s-client-kit.tar.gz" -C "${rpmbuild_dir}/SOURCES" k8s-client-kit

    #
    # rpm specファイルを生成する
    #
    cat > "${rpmbuild_dir}/SPECS/${K8S_CLIENT_RPM_PACKAGE_NAME}.spec" <<EOF
Name:           ${K8S_CLIENT_RPM_PACKAGE_NAME}
Version:        ${package_version}
Release:        1%{?dist}
Summary:        Offline kit for Kubernetes Go client
License:        Apache-2.0
BuildArch:      noarch
Source0:        k8s-client-kit.tar.gz

%description
Offline kit for Kubernetes Go client ${K8S_CLIENT_GO_VERSION}

%prep
%setup -q -n k8s-client-kit

%build

%install
rm -rf %{buildroot}
mkdir -p %{buildroot}${K8S_CLIENT_INSTALL_DIR}
cp -a go.mod go.sum vendor %{buildroot}${K8S_CLIENT_INSTALL_DIR}/

%files
${K8S_CLIENT_INSTALL_DIR}/go.mod
${K8S_CLIENT_INSTALL_DIR}/go.sum
${K8S_CLIENT_INSTALL_DIR}/vendor
EOF

    #
    # RPMパッケージをビルドする
    #
    rpmbuild -bb "${rpmbuild_dir}/SPECS/${K8S_CLIENT_RPM_PACKAGE_NAME}.spec" --define "_topdir ${rpmbuild_dir}"

    #
    # ビルドされたrpmパッケージを /work/output にコピーする
    #
    find "${rpmbuild_dir}/RPMS" -type f -name '*.rpm' -exec cp -f {} "${outdir}/" \;
}

#
# メイン処理
#
main(){

    # Go言語版 Kubernetes クライアントのオフラインキットを構築し,
    # rpmパッケージをビルドする
    build_package
}

main "$@"