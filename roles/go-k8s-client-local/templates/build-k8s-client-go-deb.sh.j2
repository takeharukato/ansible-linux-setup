#!/usr/bin/env bash
# -*- coding:utf-8 mode:bash -*-
#
# Go 言語版 Kubernetes client のdebパッケージをビルドする
#
# 実行時パラメタ環境変数
#  - K8S_CLIENT_GO_VERSION: ビルド対象の client-go 版数 (vX.Y.Z)
#  - K8S_CLIENT_MODULE_DOMAIN: go module domain
#  - K8S_CLIENT_DEB_PACKAGE_NAME: 生成するdebパッケージ名
#  - K8S_CLIENT_INSTALL_DIR: オフラインキット(*)導入先
#    (*) 導入先ディレクトリに go.mod, go.sum, vendor/ が配置されるという意味。
#
# This file is generated by ansible.
{# 日付の取得 #}
# last update: {{ '%Y-%m-%d %H:%M:%S %Z' | strftime(ansible_date_time.epoch) }}

set -euo pipefail

#
# 環境変数設定
#
: "${K8S_CLIENT_GO_VERSION:?K8S_CLIENT_GO_VERSION is required}"
: "${K8S_CLIENT_MODULE_DOMAIN:?K8S_CLIENT_MODULE_DOMAIN is required}"
: "${K8S_CLIENT_DEB_PACKAGE_NAME:?K8S_CLIENT_DEB_PACKAGE_NAME is required}"
: "${K8S_CLIENT_INSTALL_DIR:?K8S_CLIENT_INSTALL_DIR is required}"

#
# 作業ディレクトリの設定
#
workdir="{{ go_k8s_client_build_container_workdir }}"
outdir="${workdir}/output"
stage_dir="${workdir}/k8s-client-deb-stage"
pkgroot="${stage_dir}/root"
control_dir="${pkgroot}/DEBIAN"
module_dir="${workdir}/module"
package_version="${K8S_CLIENT_GO_VERSION#v}"
module_name="${K8S_CLIENT_MODULE_DOMAIN}/k8s-devel-client-go"

#
# Go言語版 Kubernetes クライアントのオフラインキット構築処理
# Kubernetes クライアントモジュールを構築し, パッケージ生成時の
# ステージングディレクトリにコピーする
#
build_offline_kit(){
    local dir

    #
    # ステージングディレクトリの初期化
    #
    if [ -d "${stage_dir}" ]; then
        rm -rf "${stage_dir:?}/"*
    fi
    mkdir -p "${stage_dir}"

    #
    # オフラインキット構築のためのディレクトリを作成
    #
    if [ -d "${module_dir}" ]; then
        rm -rf "${module_dir:?}/"*
    else
        mkdir -p "${module_dir}"
    fi

    #
    # 必要なディレクトリを作成
    #
    for dir in "${outdir}" \
                "${control_dir}" \
                "${pkgroot}${K8S_CLIENT_INSTALL_DIR}"; do
        mkdir -p "${dir}"
    done

    #
    # Go言語版 Kubernetes クライアントのオフラインキットを構築する
    #
    cd "${module_dir}"

    #
    # go mod init で go module を初期化する
    #
    go mod init "${module_name}"
    go get "k8s.io/client-go@${K8S_CLIENT_GO_VERSION}"
    go mod vendor

    #
    # オフラインキットをステージングディレクトリにコピーする
    #
    cp -f "${module_dir}/go.mod" "${pkgroot}${K8S_CLIENT_INSTALL_DIR}/go.mod"
    cp -f "${module_dir}/go.sum" "${pkgroot}${K8S_CLIENT_INSTALL_DIR}/go.sum"
    cp -a "${module_dir}/vendor" "${pkgroot}${K8S_CLIENT_INSTALL_DIR}/vendor"
}

#
# debパッケージ構築処理
# ステージングディレクトリ配下の生成物をdebパッケージにまとめる
#
build_package(){
    local installed_size

    #
    # debパッケージの制御情報を生成する
    #
    installed_size="$(du -ks "${pkgroot}" | awk '{print $1}')"

    cat > "${control_dir}/control" <<EOF
Package: ${K8S_CLIENT_DEB_PACKAGE_NAME}
Version: ${package_version}-1
Section: devel
Priority: optional
Architecture: all
Maintainer: go-k8s-client-local builder <root@localhost>
Installed-Size: ${installed_size}
Description: Offline kit for Kubernetes Go client ${K8S_CLIENT_GO_VERSION}
EOF

    #
    # debパッケージを生成する
    #
    dpkg-deb --build "${pkgroot}" "${outdir}/${K8S_CLIENT_DEB_PACKAGE_NAME}_${package_version}-1_all.deb"
}

#
# メイン処理
#
main(){
    build_offline_kit
    build_package
}

main "$@"