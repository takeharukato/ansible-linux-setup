#
# Go 言語版 Kubernetes client 構築コンテナイメージ生成用Dockerfile (AlmaLinux9.6環境)
#

# This file is generated by ansible.
{# 日付の取得 #}
# last update: {{ '%Y-%m-%d %H:%M:%S %Z' | strftime(ansible_date_time.epoch) }}

FROM almalinux:9.6

# パッケージ構築に必要なパッケージをインストールする
RUN dnf -y install --setopt=install_weak_deps=False \
      rpm-build \
      findutils \
      tar \
      gzip \
      go \
      git \
      shadow-utils \
      bash && \
    dnf clean all && \
    rm -rf /var/cache/dnf

#
# 作業ディレクトリ設定
#
# 留意事項
# - templates/build-k8s-client-go-rpm.sh.j2 内の変数workdirに合わせて設定すること
WORKDIR {{ go_k8s_client_build_container_workdir }}