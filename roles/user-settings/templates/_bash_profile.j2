#
# .bash_profile
#
# Bash ログインシェル用の初期化ファイル。
# .bashrc を読み込んでから, systemd ssh-agent の設定を行う。
#

# .bashrc が存在する場合は読み込む
if [ -f ~/.bashrc ]; then
    . ~/.bashrc
fi

{% if user_settings_systemd_ssh_agent_skel|default(false) %}
#
# systemd ssh-agent の設定
#
# SSH 接続経由でログインしている場合は SSH_AUTH_SOCK を上書きしない (SSH agent forwarding を維持)。
# ローカルログインの場合のみ systemd ssh-agent のソケットを使用する。
#
if [ -z "${SSH_CONNECTION:-}" ]; then
    export SSH_AUTH_SOCK="{{ user_settings_systemd_ssh_agent_shell_socket_path }}"
fi
{% else %}
#
#ssh agent for GNU screen
#
# ホームディレクトリのtmpにscreen用のssh-agentのためのソケットを生成する
#
#Drived from http://www.gcd.org/blog/2006/09/100/
#
agent="${HOME}/tmp/ssh-agent-${USER}"
# ディレクトリが無ければ生成する
if [ ! -d "${HOME}/tmp" ]; then
   mkdir -p "${HOME}/tmp"
fi

if [ -S "${SSH_AUTH_SOCK}" ]; then
	case ${SSH_AUTH_SOCK} in
	/tmp/*/agent.[0-9]*)
		ln -snf "${SSH_AUTH_SOCK}" "${agent}" && export SSH_AUTH_SOCK="${agent}"
	esac
elif [ -S "${agent}" ]; then
	export SSH_AUTH_SOCK="${agent}"
else
	echo "no ssh-agent"
fi
{% endif %}
