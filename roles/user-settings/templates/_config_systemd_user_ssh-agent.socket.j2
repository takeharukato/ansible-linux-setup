#
# ssh-agent.socket - SSH Agent Socket
#
# systemd ユーザーユニット用の ssh-agent ソケットファイル。
# このソケットを有効化すると, ソケット経由で ssh-agent サービスが自動起動される。
#
# 有効化コマンド:
#   systemctl --user enable ssh-agent.socket
#   systemctl --user start ssh-agent.socket
#
# または:
#   systemctl --user enable --now ssh-agent.socket

[Unit]
Description=SSH Agent Socket

[Socket]
ListenStream={{ user_settings_systemd_ssh_agent_socket_path }}
SocketMode=0600
DirectoryMode=0700

[Install]
WantedBy=sockets.target
