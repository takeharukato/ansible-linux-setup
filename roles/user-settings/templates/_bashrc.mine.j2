# .bashrc.mine
#
# このファイルは個人用 bash 設定ファイルです。
# ユーザーが自由にカスタマイズできます。
#
# このファイルは .bashrc から自動的に読み込まれます。
#

# ------------------------------------------------
# ヒストリとヒストリサイズ
# ------------------------------------------------
# HISTFILE=~/.bash_history
# HISTSIZE=1000
# HISTFILESIZE=2000


# -------------------------------------------------
# シェル動作のカスタマイズ
# -------------------------------------------------

# 履歴に重複したコマンドを追加しない
# shopt -s histappend

# 複数行のコマンドを1行のヒストリとして保存
# shopt -s cmdhist

# コマンド入力時に履歴を自動的に検索
# bind '"\e[A":history-search-backward'
# bind '"\e[B":history-search-forward'

# ^Dでログアウトしないようにする
# IGNOREEOF=10

# -------------------------------------------------
# 外部設定ファイルの読み込み
# -------------------------------------------------

# システム補完の有効化
{% set bash_completion_primary = user_settings_bash_completion_init_path_rhel | default('/usr/share/bash-completion/bash_completion', true) %}
{% set bash_completion_secondary = user_settings_bash_completion_init_path_debian | default('/etc/bash_completion', true) %}
if [ -f {{ bash_completion_primary }} ]; then
    . {{ bash_completion_primary }}
elif [ -f {{ bash_completion_secondary }} ]; then
    . {{ bash_completion_secondary }}
fi

# プロキシ設定ファイル (存在する場合は自動読み込み)
[ -f ${HOME}/.bashrc.proxy ] && source ${HOME}/.bashrc.proxy

# 環境モジュール (Environment Modules) 設定 (存在する場合は自動読み込み)
[ -f ${HOME}/.bashrc.lmod ] && source ${HOME}/.bashrc.lmod

# -------------------------------------------------
# CLI補完設定のカスタマイズ
# -------------------------------------------------

# .ssh/known_hosts内の既知ホスト名を補完対象に追加
# complete -W "$(echo $(<~/.ssh/known_hosts | cut -f 1 -d ' ' | sort -u | tr '\n' ' '))" ssh