# registry image backup wrapper script for skopeo
# skopeo レジストリイメージバックアップ用ラッパースクリプト

set -euo pipefail

readonly PYTHON_COMMAND="{{ skopeo_python_command }}"
readonly PYTHON_SCRIPT="{{ skopeo_backup_python_script_path }}"
readonly CONFIG_PATH="{{ skopeo_backup_restore_config_path }}"

# バックアップ用Pythonスクリプトの存在と実行権限を確認する
if [[ ! -x "${PYTHON_SCRIPT}" ]]; then
  echo "ERROR: backup python script does not exist or is not executable: ${PYTHON_SCRIPT}" >&2
  exit 1
fi

# バックアップ/リストア設定ファイルの存在を確認する
if [[ ! -f "${CONFIG_PATH}" ]]; then
  echo "ERROR: backup/restore config file was not found: ${CONFIG_PATH}" >&2
  exit 1
fi

# Pythonスクリプトを実行する
exec "${PYTHON_COMMAND}" "${PYTHON_SCRIPT}" --config "${CONFIG_PATH}" "$@"
