# bash completion for skopeo
# skopeo の bash 補完ファイル
#

_skopeo_completion() {
  local cur prev
  cur="${COMP_WORDS[COMP_CWORD]}"
  prev="${COMP_WORDS[COMP_CWORD-1]}"

  case "${prev}" in
    --override-os|--override-arch|--override-variant|--policy)
      return 0
      ;;
  esac

  COMPREPLY=( $(compgen -W "copy delete inspect list-tags login logout manifest-digest sync standalone-sign standalone-verify --help --version" -- "${cur}") )
}

complete -F _skopeo_completion skopeo
