# daily backup wrapper script for skopeo
# skopeo 日次バックアップ用ラッパースクリプト

set -euo pipefail

#
# 変数定義
#
# NFS 共有先サーバとディレクトリ
readonly NFS_SERVER_OPT="{{ skopeo_backup_nfs_server }}:{{ skopeo_backup_nfs_dir }}"
# NFS マウントポイント
readonly NFS_MOUNT_POINT="{{ skopeo_backup_mount_point }}"
# NFS マウントポイント配下のバックアップ成果物配置先ディレクトリ
readonly BACKUP_OUTPUT_DIR="{{ skopeo_backup_output_dir }}"
# バックアップ用スクリプト
readonly BACKUP_SCRIPT="{{ skopeo_backup_script_path }}"
# ローカルホスト上のバックアップディレクトリ
readonly LOCAL_BACKUP_DIR="{{ skopeo_backup_dir }}"
# バックアップアーカイブの接頭辞
readonly ARCHIVE_PREFIX="{{ skopeo_backup_archive_prefix }}"

# バックアップ用スクリプトの存在と実行権限を確認する
if [[ ! -x "${BACKUP_SCRIPT}" ]]; then

    # バックアップ用スクリプトが存在しないか実行権限がない場合はエラーを出力して終了する
    echo "ERROR: backup script does not exist or is not executable: ${BACKUP_SCRIPT}" >&2
    exit 1
fi

# バックアップ処理を実行する。
do_backup() {

    "${BACKUP_SCRIPT}"
}

# 管理者権限が必要なコマンドを実行する。
run_privileged() {

    # root 権限で実行されている場合は,
    # 引数で指定されたコマンドをそのまま実行する
    if [[ "${EUID}" -eq 0 ]]; then
        "$@"
        return
    fi

    # sudo コマンドが存在するか確認し,
    # 存在しない場合はエラーを出力して終了する
    if ! command -v sudo >/dev/null 2>&1; then
        echo "ERROR: sudo command is required for privileged operations" >&2
        return 1
    fi

    # sudo コマンドを使用して, 引数で指定されたコマンドを管理者権限で実行する
    sudo "$@"
}

# NFSコピーに必要な設定値を検証する。
validate_nfs_settings() {

    if [[ -z "{{ skopeo_backup_nfs_server }}" ]]; then
        # NFSサーバが空の場合はエラーを出力して終了する
        echo "ERROR: skopeo_backup_nfs_server is empty" >&2
        return 1
    fi

    if [[ -z "{{ skopeo_backup_nfs_dir }}" ]]; then
        # NFS共有ディレクトリが空の場合はエラーを出力して終了する
        echo "ERROR: skopeo_backup_nfs_dir is empty" >&2
        return 1
    fi
}

# NFS 共有へ最新バックアップアーカイブをコピーする。
copy_latest_backup_to_nfs() {
    local latest_archive=""

    # NFS共有ディレクトリをマウントする
    if ! run_privileged mount -t nfs "${NFS_SERVER_OPT}" "${NFS_MOUNT_POINT}"; then

        # NFSマウントに失敗した場合はエラーを出力して終了する
        echo "ERROR: failed to mount NFS share: ${NFS_SERVER_OPT} -> ${NFS_MOUNT_POINT}" >&2
        return 1
    fi

    # NFSマウントポイントが正しくマウントされていることを確認する
    if ! mountpoint "${NFS_MOUNT_POINT}" >/dev/null 2>&1; then

        # NFSマウントポイントが正しくマウントされていない場合はエラーを出力して終了する
        echo "ERROR: mount point check failed: ${NFS_MOUNT_POINT}" >&2
        run_privileged umount "${NFS_MOUNT_POINT}" || true
        return 1
    fi

    # バックアップ成果物配置先ディレクトリを作成し, 書き込み権限を設定する
    # NASなどの仕様に依存しないようにフルアクセス権限(0777)を設定する
    run_privileged mkdir -p "${BACKUP_OUTPUT_DIR}"
    run_privileged chmod 0777 "${BACKUP_OUTPUT_DIR}"

    #
    # ローカルホスト上の最新バックアップアーカイブを取得する
    #
    # 以下のコマンドを実行して, 最新のバックアップアーカイブを取得する:
    # - ls -1t: ファイルを更新日時の降順でリストする
    # - head -n 1: リストの先頭1行を取得する
    latest_archive="$(ls -1t "${LOCAL_BACKUP_DIR}/${ARCHIVE_PREFIX}"-*.tar.gz 2>/dev/null | head -n 1 || true)"
    if [[ -z "${latest_archive}" || ! -f "${latest_archive}" ]]; then

        # 最新のバックアップアーカイブが存在しない場合はエラーを出力して終了する
        echo "ERROR: no backup archive found in ${LOCAL_BACKUP_DIR}" >&2
        run_privileged umount "${NFS_MOUNT_POINT}" || true
        return 1
    fi

    # 最新のバックアップアーカイブをNFS共有ディレクトリへコピーする
    run_privileged cp "${latest_archive}" "${BACKUP_OUTPUT_DIR}/"
    run_privileged umount "${NFS_MOUNT_POINT}"
}

# メイン処理
main() {

    validate_nfs_settings
    do_backup
    copy_latest_backup_to_nfs
}

main "$@"
