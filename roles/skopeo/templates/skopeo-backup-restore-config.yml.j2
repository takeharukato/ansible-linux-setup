# skopeo backup/restore shared settings
# skopeo backup/restore 設定ファイル

registry_endpoints: {{ skopeo_registry_endpoints | default([], true) | to_json }}
backup_dir: "{{ skopeo_backup_dir }}"

backup:
  work_dir: "{{ skopeo_backup_work_dir }}"
  archive_prefix: "{{ skopeo_backup_archive_prefix }}"
  rotation: {{ skopeo_backup_rotation | int }}
  image_list: {{ skopeo_backup_image_list | default([], true) | to_json }}

restore:
  default_destination_registry: "{{ skopeo_restore_default_destination_registry | default('', true) }}"
